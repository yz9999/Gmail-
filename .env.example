# 完整的 Gmail 地址
GMAIL_ADDRESS=yourname@gmail.com

# Google 生成的 16 位应用专用密码，可带空格，程序会自动移除空格
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# 一般无需修改
GMAIL_FOLDER=INBOX
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# 使用代理软件时启用。类型支持 socks5、socks4、http；留空表示直连。
# Clash Verge/Surge 常见 SOCKS 端口分别为 7891/6153。
GMAIL_PROXY_TYPE=
GMAIL_PROXY_HOST=127.0.0.1
GMAIL_PROXY_PORT=6153
GMAIL_PROXY_RDNS=true

# 网页中的“写邮件”功能使用以下 SMTP 配置
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465

# 本地 Web 服务（macOS 的 5000 端口通常被 AirPlay 占用）
GMAIL_WEB_HOST=127.0.0.1
GMAIL_WEB_PORT=5001
# Web 登录密码，请使用足够长的随机字符串
GMAIL_WEB_TOKEN=replace-with-a-random-token

# 多账号配置文件。网页添加的账号会保存到这里（已被 git 忽略）。
GMAIL_ACCOUNTS_FILE=accounts.json
